# Browser-safe values only. Never place service_role, secret keys, database
# passwords, provider client secrets, or Supabase access tokens in this file.
SUPABASE_URL=http://127.0.0.1:55221
SUPABASE_PUBLISHABLE_KEY=replace_with_local_publishable_key

# Price Radar (Vite) will use these names when its separate repo is integrated.
VITE_SUPABASE_URL=http://127.0.0.1:55221
VITE_SUPABASE_PUBLISHABLE_KEY=replace_with_local_publishable_key
